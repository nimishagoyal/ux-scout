# Anthropic API key — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Mobbin OAuth token — run: security find-generic-password -s "claude-mcp-mobbin" -w
# Or get from mobbin.com account settings → API / MCP token
# If not set, Claude falls back to knowledge-based analysis (no live screenshots)
MOBBIN_AUTH_TOKEN=
